# Database connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oura

# Test database (used by pytest)
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5433/oura_test

# Oura OAuth credentials
# Get these from https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=your_client_id_here
OURA_CLIENT_SECRET=your_client_secret_here
OURA_REDIRECT_URI=http://localhost:3000/api/oura/callback

# Token encryption key (REQUIRED — Fernet symmetric key for encrypting Oura tokens at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Auto-migration (set to true for development, false for production)
ENABLE_AUTO_MIGRATE=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Session lifetime (hours, default 720 = 30 days)
# SESSION_MAX_AGE_HOURS=720

# Login rate limiting (attempts per minute per IP, default 10)
# LOGIN_RATE_LIMIT_PER_MINUTE=10

# Runtime DB role guard (optional — set to verify the DB connection role)
# EXPECTED_DB_ROLE=app_user

# OpenAI (for chat agent feature)
# OPENAI_API_KEY=sk-...
# CHAT_ENABLED=false
