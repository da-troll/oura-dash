# Database (use a strong password in production)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=oura

# Oura OAuth credentials
# Get these from https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=your_client_id_here
OURA_CLIENT_SECRET=your_client_secret_here

# Token encryption key (REQUIRED — Fernet symmetric key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Auto-migration (false for production — run migrations manually or via deploy script)
ENABLE_AUTO_MIGRATE=false

# Runtime DB role guard (optional — set to verify connection role in production)
# EXPECTED_DB_ROLE=app_user

# OpenAI chat agent (optional)
# OPENAI_API_KEY=sk-...
# CHAT_ENABLED=false
